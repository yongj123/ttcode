{
  "name": "ttcode",
  "version": "0.1.0",
  "description": "ttcode - AI coding assistant for your terminal",
  "license": "MIT",
  "type": "module",
  "bin": {
    "ttcode": "./dist/cli.js"
  },
  "files": [
    "dist/cli.js"
  ],
  "scripts": {
    "typecheck": "tsc -p ./ --noEmit",
    "bundle": "bun build ./src/cli.tsx --outdir=dist --target=bun --format=esm --external react-devtools-core",
    "build": "bun run typecheck && bun run bundle",
    "dev": "bun run --watch src/cli.tsx",
    "start": "bun run src/cli.tsx"
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "ink": "^5.2.0",
    "ink-text-input": "^6.0.0",
    "openai": "^5.20.0",
    "react": "^19.1.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/react": "^19.1.0",
    "typescript": "^5.8.0"
  }
}
